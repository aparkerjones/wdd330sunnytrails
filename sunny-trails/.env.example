# National Park Service API
VITE_NPS_API_KEY=your_nps_api_key_here
VITE_NPS_BASE_URL=https://developer.nps.gov/api/v1

# Open-Meteo API (kept configurable in case the setup changes later)
VITE_OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Default fallback coordinates for a general U.S. location
VITE_DEFAULT_LAT=39.8283
VITE_DEFAULT_LON=-98.5795
